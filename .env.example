# ============================================================================
# ITBengal Hosting Platform — Environment Variables
# ============================================================================
# Copy this file to .env and fill in the values.
# NEVER commit .env files with real credentials.
# ============================================================================

# --------------------------------------------------------------------------
# General
# --------------------------------------------------------------------------
NODE_ENV=development
PORT=4000
APP_NAME=ITBengal
APP_URL=http://localhost:3000
API_URL=http://localhost:4000
ADMIN_URL=http://localhost:3001
DOMAIN=itbengal.xyz

# --------------------------------------------------------------------------
# Database (PostgreSQL 16)
# --------------------------------------------------------------------------
DATABASE_URL=postgresql://itbengal:itbengal_dev_password@localhost:5432/itbengal?schema=public
DATABASE_POOL_MIN=2
DATABASE_POOL_MAX=10

# --------------------------------------------------------------------------
# Redis 7
# --------------------------------------------------------------------------
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=
REDIS_DB=0

# --------------------------------------------------------------------------
# JWT Authentication (RS256)
# --------------------------------------------------------------------------
# Generate with: openssl genrsa -out private.pem 2048
#                openssl rsa -in private.pem -pubout -out public.pem
JWT_ACCESS_SECRET=your-access-secret-change-in-production
JWT_REFRESH_SECRET=your-refresh-secret-change-in-production
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d
JWT_ISSUER=itbengal.xyz

# --------------------------------------------------------------------------
# Encryption
# --------------------------------------------------------------------------
# Generate with: openssl rand -hex 32
ENCRYPTION_KEY=your-32-byte-hex-encryption-key-change-this

# --------------------------------------------------------------------------
# Email (Self-hosted SMTP)
# --------------------------------------------------------------------------
SMTP_HOST=localhost
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_NAME=ITBengal
SMTP_FROM_EMAIL=noreply@itbengal.xyz

# For local dev, use Mailpit (http://localhost:8025)
# SMTP_HOST=localhost
# SMTP_PORT=1025

# --------------------------------------------------------------------------
# GitHub OAuth (for Git repository imports)
# --------------------------------------------------------------------------
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret
GITHUB_CALLBACK_URL=http://localhost:4000/api/v1/auth/github/callback

# --------------------------------------------------------------------------
# bKash Payment Gateway
# --------------------------------------------------------------------------
# Leave empty until merchant account is obtained
BKASH_API_URL=https://tokenized.sandbox.bka.sh/v1.2.0-beta
BKASH_APP_KEY=
BKASH_APP_SECRET=
BKASH_USERNAME=
BKASH_PASSWORD=
BKASH_CALLBACK_URL=http://localhost:4000/api/v1/payments/bkash/callback

# --------------------------------------------------------------------------
# Docker (Deployment Engine)
# --------------------------------------------------------------------------
DOCKER_SOCKET=/var/run/docker.sock
DOCKER_NETWORK=itbengal-hosting
CONTAINER_REGISTRY=registry.itbengal.xyz

# --------------------------------------------------------------------------
# Traefik
# --------------------------------------------------------------------------
TRAEFIK_API_URL=http://localhost:8080
TRAEFIK_NETWORK=traefik-public
ACME_EMAIL=admin@itbengal.xyz

# --------------------------------------------------------------------------
# Openprovider (Domain Registration) — Phase 2
# --------------------------------------------------------------------------
OPENPROVIDER_API_URL=https://api.openprovider.eu/v1beta
OPENPROVIDER_USERNAME=
OPENPROVIDER_PASSWORD=

# --------------------------------------------------------------------------
# Monitoring
# --------------------------------------------------------------------------
PROMETHEUS_URL=http://localhost:9090
GRAFANA_URL=http://localhost:3001
LOKI_URL=http://localhost:3100

# --------------------------------------------------------------------------
# Rate Limiting
# --------------------------------------------------------------------------
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_AUTH_MAX=20

# --------------------------------------------------------------------------
# File Upload
# --------------------------------------------------------------------------
MAX_UPLOAD_SIZE=104857600
UPLOAD_DIR=./uploads

# --------------------------------------------------------------------------
# Logging
# --------------------------------------------------------------------------
LOG_LEVEL=debug
LOG_FORMAT=json

# --------------------------------------------------------------------------
# Next.js Dashboard (Client-side)
# --------------------------------------------------------------------------
NEXT_PUBLIC_API_URL=http://localhost:4000/api/v1
NEXT_PUBLIC_WS_URL=ws://localhost:4001
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=ITBengal
